---
import { whatsappUrl, PHONE_DISPLAY, PHONE_TEL, EMAIL } from '../data/locations';
---

<footer class="bg-dark text-white" style="padding: 3.5rem 1.25rem 2rem;">
  <div class="grid grid-cols-1 md:grid-cols-[2fr_1fr_1fr_1fr] gap-8 max-w-[1200px] mx-auto">
    <!-- Column 1: Logo + Venues + Contact -->
    <div>
      <div class="flex items-center gap-[0.6rem] mb-2">
        <img
          src="/images/logos/logo-mark-golden-tight.png"
          alt="Latin Addiction logo"
          width="44"
          height="44"
          loading="lazy"
          style="height: 44px; width: auto; filter: brightness(1.15);"
        />
        <span class="font-display font-bold text-base" style="margin-bottom: 0;">Latin Addiction UK</span>
      </div>

      <p class="text-[0.82rem] leading-[1.7]" style="color: rgba(255,255,255,0.5);">
        <strong class="text-white">Milton Keynes:</strong> Midsummer Tap, Theatre District, Milton Keynes MK9 3PU — Mondays from 7:45pm
      </p>
      <p class="text-[0.82rem] leading-[1.7] mt-[0.4rem]" style="color: rgba(255,255,255,0.5);">
        <strong class="text-white">Leicester:</strong> Braunstone Frith Recreation Centre, 29A Sharmon Cres, Leicester LE3 6NW — Tuesdays from 7:00pm
      </p>
      <p class="text-[0.82rem] leading-[1.7] mt-[0.4rem]" style="color: rgba(255,255,255,0.5);">
        <strong class="text-white">Reading:</strong> Wesley Methodist Church, 84 Queen's Rd, Reading RG1 4BW — Wednesdays from 7:45pm
      </p>

      <p class="text-[0.82rem] leading-[1.7] mt-3" style="color: rgba(255,255,255,0.5);">
        <strong class="text-white">WhatsApp:</strong>{' '}
        <a href={whatsappUrl()} class="footer-link">{PHONE_DISPLAY}</a><br />
        <strong class="text-white">Phone:</strong>{' '}
        <a href={`tel:${PHONE_TEL}`} class="footer-link">{PHONE_DISPLAY}</a><br />
        <strong class="text-white">Email:</strong>{' '}
        <a href={`mailto:${EMAIL}`} class="footer-link">{EMAIL}</a>
      </p>
    </div>

    <!-- Column 2: Pages -->
    <div>
      <p class="font-display font-bold text-base mb-[0.65rem]">Pages</p>
      <ul class="flex flex-col gap-[0.35rem] list-none">
        <li><a href="/" class="footer-link text-[0.82rem]">Home</a></li>
        <li><a href="/milton-keynes" class="footer-link text-[0.82rem]">Milton Keynes</a></li>
        <li><a href="/leicester" class="footer-link text-[0.82rem]">Leicester</a></li>
        <li><a href="/reading" class="footer-link text-[0.82rem]">Reading</a></li>
        <li><a href="/pricing" class="footer-link text-[0.82rem]">Pricing</a></li>
        <li><a href="/classes" class="footer-link text-[0.82rem]">Classes</a></li>
      </ul>
    </div>

    <!-- Column 3: Services -->
    <div>
      <p class="font-display font-bold text-base mb-[0.65rem]">Services</p>
      <ul class="flex flex-col gap-[0.35rem] list-none">
        <li><a href="/services/private-coaching" class="footer-link text-[0.82rem]">Private Coaching</a></li>
        <li><a href="/services/corporate" class="footer-link text-[0.82rem]">Corporate</a></li>
        <li><a href="/services/hire-us" class="footer-link text-[0.82rem]">Hire Us</a></li>
      </ul>
    </div>

    <!-- Column 4: Connect -->
    <div>
      <p class="font-display font-bold text-base mb-[0.65rem]">Connect</p>
      <ul class="flex flex-col gap-[0.35rem] list-none">
        <li><a href="https://www.instagram.com/latinaddictionuk" target="_blank" rel="noopener" class="footer-link text-[0.82rem]">Instagram</a></li>
        <li><a href="https://www.facebook.com/LatinAddictionUK" target="_blank" rel="noopener" class="footer-link text-[0.82rem]">Facebook</a></li>
        <li><a href="https://www.tiktok.com/@latin.addiction.uk" target="_blank" rel="noopener" class="footer-link text-[0.82rem]">TikTok</a></li>
        <li><a href="https://www.youtube.com/@LatinAddictionUK" target="_blank" rel="noopener" class="footer-link text-[0.82rem]">YouTube</a></li>
        <li><a href="/about" class="footer-link text-[0.82rem]">Our Story</a></li>
        <li><a href="/faq" class="footer-link text-[0.82rem]">FAQ</a></li>
        <li><a href="/reviews" class="footer-link text-[0.82rem]">Reviews</a></li>
      </ul>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="max-w-[1200px] mx-auto mt-8 pt-5 flex flex-wrap justify-between gap-4 text-[0.75rem]" style="border-top: 1px solid rgba(255,255,255,0.06); color: rgba(255,255,255,0.5);">
    <p>Student &amp; NHS discount available — <a href={whatsappUrl()} class="footer-link">ask us on WhatsApp</a>.</p>
    <p><a href="/privacy" class="footer-link">Privacy Policy</a> &middot; &copy; 2026 Latin Addiction UK Ltd</p>
  </div>
</footer>

<style>
  .footer-link {
    color: rgba(255, 255, 255, 0.5);
    text-decoration: none;
    transition: color 0.2s;
  }
  .footer-link:hover {
    color: #fff;
  }
</style>
