---
interface Props {
  waUrl?: string;
}
---

<script>
  const STORE_ROOT = 'https://latinaddictionuk.sumupstore.com/';

  document.querySelectorAll<HTMLButtonElement>('.btn-checkout').forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      const target = btn.dataset.storeUrl || STORE_ROOT;
      window.open(target, '_blank', 'noopener');
    });
  });
</script>
