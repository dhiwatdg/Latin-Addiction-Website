---
import BaseLayout from '../layouts/BaseLayout.astro';
import { whatsappUrl } from '../data/locations';

const waUrl = whatsappUrl("Hi! I'm not sure which level to join — can you help?");
---

<BaseLayout
  title="Class Levels — Bachata & Salsa"
  description="Find your level at Latin Addiction UK. Beginner to Advanced Bachata classes in Milton Keynes, Leicester, and Reading. Salsa also available in Milton Keynes."
>
  {/* ── HERO ── */}
  <section class="relative overflow-hidden bg-dark text-white flex items-center min-h-[45vh] px-5 py-14 md:px-8 md:py-20">
    <div class="hero-glow-left" aria-hidden="true"></div>
    <div class="hero-glow-right" aria-hidden="true"></div>

    <div class="relative z-10 max-w-[1200px] mx-auto w-full text-center">
      <div data-reveal class="flex items-center gap-3 mb-3 justify-center">
        <span class="text-rose-light uppercase text-xs font-bold tracking-[0.12em]">
          Class levels
        </span>
      </div>

      <h1 data-reveal data-reveal-delay="1" class="font-display font-extrabold text-white leading-[1.05] tracking-[-0.02em] mb-5 text-[clamp(2.5rem,6vw,4.5rem)]">
        Find your level
      </h1>

      <p data-reveal data-reveal-delay="2" class="font-body font-light text-[clamp(1rem,2vw,1.15rem)] text-white/60 leading-[1.7] max-w-[560px] mb-8 mx-auto">
        Whether you've never danced before or you're already a confident social dancer — there's a class for you.
      </p>
    </div>
  </section>

  {/* ── PROGRESSION PATH ── */}
  <section class="bg-white px-5 py-14 md:px-8 md:py-20 lg:px-8 lg:py-24">
    <div class="max-w-[860px] mx-auto">
      <div data-reveal class="mb-3">
        <span class="text-rose uppercase text-[0.75rem] font-bold tracking-[0.12em]">
          Bachata
        </span>
      </div>
      <h2 data-reveal data-reveal-delay="1" class="font-display font-semibold text-[clamp(1.75rem,3.5vw,2.75rem)] leading-[1.12] mb-10">
        The progression path
      </h2>

      {/* Level cards */}
      <div class="flex flex-col gap-6">

        {/* Beginners */}
        <div data-reveal class="border-[1.5px] border-[#e8e8e8] rounded-[18px] p-6 md:p-8 bg-white">
          <div class="flex flex-wrap items-start gap-4 mb-4">
            <span class="inline-block bg-rose text-white text-[0.75rem] font-bold uppercase tracking-[0.1em] px-3 py-1 rounded-full">
              Level 1
            </span>
            <div>
              <h3 class="font-display font-bold text-[1.25rem] leading-tight">Beginners</h3>
              <p class="text-rose-dark font-semibold text-[0.88rem]">Never danced Bachata? Start here.</p>
            </div>
          </div>
          <p class="text-[0.95rem] text-muted leading-[1.7] mb-4">
            Learn the basic step, partner connection, and simple turns. No experience needed — we build from the ground up.
          </p>
          <div class="flex flex-wrap gap-2">
            <span class="text-[0.8rem] bg-[#f5f5f5] rounded-full px-3 py-1 text-dark/70">Milton Keynes</span>
            <span class="text-[0.8rem] bg-[#f5f5f5] rounded-full px-3 py-1 text-dark/70">Leicester</span>
            <span class="text-[0.8rem] bg-[#f5f5f5] rounded-full px-3 py-1 text-dark/70">Reading</span>
          </div>
        </div>

        {/* Improvers */}
        <div data-reveal data-reveal-delay="1" class="border-[1.5px] border-[#e8e8e8] rounded-[18px] p-6 md:p-8 bg-white">
          <div class="flex flex-wrap items-start gap-4 mb-4">
            <span class="inline-block bg-rose/80 text-white text-[0.75rem] font-bold uppercase tracking-[0.1em] px-3 py-1 rounded-full">
              Level 2
            </span>
            <div>
              <h3 class="font-display font-bold text-[1.25rem] leading-tight">Improvers</h3>
              <p class="text-rose-dark font-semibold text-[0.88rem]">You know the basics. Now build your vocabulary.</p>
            </div>
          </div>
          <p class="text-[0.95rem] text-muted leading-[1.7] mb-4">
            You know the basic step and a few moves. Now we add more turns, body movement, and musicality — developing your feel for the dance.
          </p>
          <div class="flex flex-wrap gap-2">
            <span class="text-[0.8rem] bg-[#f5f5f5] rounded-full px-3 py-1 text-dark/70">Milton Keynes</span>
            <span class="text-[0.8rem] bg-[#f5f5f5] rounded-full px-3 py-1 text-dark/70">Leicester (separate class)</span>
            <span class="text-[0.8rem] bg-[#f5f5f5] rounded-full px-3 py-1 text-dark/70">Reading (combined with Intermediate)</span>
          </div>
        </div>

        {/* Intermediate */}
        <div data-reveal data-reveal-delay="2" class="border-[1.5px] border-[#e8e8e8] rounded-[18px] p-6 md:p-8 bg-white">
          <div class="flex flex-wrap items-start gap-4 mb-4">
            <span class="inline-block bg-rose/60 text-white text-[0.75rem] font-bold uppercase tracking-[0.1em] px-3 py-1 rounded-full">
              Level 3
            </span>
            <div>
              <h3 class="font-display font-bold text-[1.25rem] leading-tight">Intermediate</h3>
              <p class="text-rose-dark font-semibold text-[0.88rem]">Dance socially with confidence.</p>
            </div>
          </div>
          <p class="text-[0.95rem] text-muted leading-[1.7] mb-4">
            You can hold your own on any social floor. Now refine your technique, learn complex combinations, and start to develop your own style.
          </p>
          <div class="flex flex-wrap gap-2">
            <span class="text-[0.8rem] bg-[#f5f5f5] rounded-full px-3 py-1 text-dark/70">Milton Keynes (combined with Advanced)</span>
            <span class="text-[0.8rem] bg-[#f5f5f5] rounded-full px-3 py-1 text-dark/70">Leicester (separate class)</span>
            <span class="text-[0.8rem] bg-[#f5f5f5] rounded-full px-3 py-1 text-dark/70">Reading (combined with Improvers)</span>
          </div>
        </div>

        {/* Advanced */}
        <div data-reveal data-reveal-delay="3" class="border-[1.5px] border-[#e8e8e8] rounded-[18px] p-6 md:p-8 bg-white">
          <div class="flex flex-wrap items-start gap-4 mb-4">
            <span class="inline-block bg-dark text-white text-[0.75rem] font-bold uppercase tracking-[0.1em] px-3 py-1 rounded-full">
              Level 4
            </span>
            <div>
              <h3 class="font-display font-bold text-[1.25rem] leading-tight">Advanced</h3>
              <p class="text-rose-dark font-semibold text-[0.88rem]">Strong social dancer. Now go deeper.</p>
            </div>
          </div>
          <p class="text-[0.95rem] text-muted leading-[1.7] mb-4">
            Advanced technique, intricate combinations, and performance quality. For strong social dancers who want to push further.
          </p>
          <div class="flex flex-wrap gap-2">
            <span class="text-[0.8rem] bg-[#f5f5f5] rounded-full px-3 py-1 text-dark/70">Leicester only</span>
          </div>
        </div>

      </div>

      {/* "How do I know when I'm ready?" callout */}
      <div data-reveal class="mt-8 bg-rose/[0.06] border border-rose/20 rounded-[18px] p-6 md:p-8">
        <h3 class="font-display font-bold text-[1.1rem] mb-2">How do I know when I'm ready to move up?</h3>
        <p class="text-[0.95rem] text-muted leading-[1.7]">
          Not sure which level suits you? Just ask us. Most people stay in Beginners for 2–3 months, then move up when they feel ready. There's no test — we'll let you know when we think you're there.
        </p>
      </div>

    </div>
  </section>

  {/* ── MK SALSA NOTE ── */}
  <section class="bg-[#f5f5f5] px-5 py-14 md:px-8 md:py-20">
    <div class="max-w-[860px] mx-auto">
      <div data-reveal class="mb-3">
        <span class="text-rose uppercase text-[0.75rem] font-bold tracking-[0.12em]">
          Also at Milton Keynes
        </span>
      </div>
      <h2 data-reveal data-reveal-delay="1" class="font-display font-semibold text-[clamp(1.5rem,3vw,2.25rem)] leading-[1.12] mb-4">
        Salsa classes
      </h2>
      <p data-reveal data-reveal-delay="2" class="text-[0.95rem] text-muted leading-[1.7] max-w-[620px] mb-6">
        Milton Keynes is our only location offering Salsa. After the Bachata classes, we run a full Salsa session — Beginners, Improvers, and Intermediate-Advanced, all on the same Monday night.
      </p>
      <div data-reveal data-reveal-delay="3">
        <a href="/milton-keynes#schedule" class="text-rose-dark font-semibold text-[0.92rem] no-underline hover:underline">
          See the Milton Keynes schedule →
        </a>
      </div>
    </div>
  </section>

  {/* ── LOCATION LINKS ── */}
  <section class="bg-white px-5 py-14 md:px-8 md:py-20">
    <div class="max-w-[860px] mx-auto">
      <h2 data-reveal class="font-display font-semibold text-[clamp(1.5rem,3vw,2.25rem)] leading-[1.12] mb-8">
        Where we teach
      </h2>
      <div class="grid gap-4 md:grid-cols-3">
        <a data-reveal data-reveal-delay="1" href="/milton-keynes" class="block border-[1.5px] border-[#e8e8e8] rounded-[18px] p-6 no-underline hover:border-rose/40 transition-colors group">
          <p class="font-display font-bold text-[1.05rem] group-hover:text-rose transition-colors mb-1">Milton Keynes</p>
          <p class="text-[0.82rem] text-muted">Bachata + Salsa · Every Monday</p>
        </a>
        <a data-reveal data-reveal-delay="2" href="/leicester" class="block border-[1.5px] border-[#e8e8e8] rounded-[18px] p-6 no-underline hover:border-rose/40 transition-colors group">
          <p class="font-display font-bold text-[1.05rem] group-hover:text-rose transition-colors mb-1">Leicester</p>
          <p class="text-[0.82rem] text-muted">Bachata · Every Tuesday</p>
        </a>
        <a data-reveal data-reveal-delay="3" href="/reading" class="block border-[1.5px] border-[#e8e8e8] rounded-[18px] p-6 no-underline hover:border-rose/40 transition-colors group">
          <p class="font-display font-bold text-[1.05rem] group-hover:text-rose transition-colors mb-1">Reading</p>
          <p class="text-[0.82rem] text-muted">Bachata · Every Wednesday</p>
        </a>
      </div>
    </div>
  </section>

  {/* ── FINAL CTA ── */}
  <section class="relative overflow-hidden bg-dark px-5 py-14 md:px-8 md:py-20 lg:px-8 lg:py-24">
    <div class="hero-glow-left" aria-hidden="true"></div>
    <div class="hero-glow-right" aria-hidden="true"></div>

    <div class="relative z-10 max-w-[1200px] mx-auto text-center">
      <h2 data-reveal class="font-display font-bold text-white leading-[1.08] tracking-[-0.02em] mb-4 text-[clamp(2rem,5vw,3.5rem)]">
        Not sure where you fit?
      </h2>
      <p data-reveal data-reveal-delay="1" class="text-[clamp(1rem,2vw,1.12rem)] text-white/[0.55] max-w-[500px] mx-auto leading-[1.7] mb-8">
        Message us on WhatsApp and we'll point you in the right direction.
      </p>
      <div data-reveal data-reveal-delay="2">
        <a href={waUrl} class="btn-rose" style="font-size:1.02rem;padding:1rem 2.25rem;" target="_blank" rel="noopener">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
            <path d="M12 0C5.373 0 0 5.373 0 12c0 2.625.846 5.059 2.284 7.034L.789 23.492a.5.5 0 00.611.611l4.458-1.495A11.96 11.96 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-2.336 0-4.512-.703-6.32-1.905l-.44-.303-2.882.966.966-2.882-.303-.44A9.935 9.935 0 012 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/>
          </svg>
          Message us on WhatsApp
        </a>
      </div>
    </div>
  </section>

  {/* ── JSON-LD SCHEMA ── */}
  <script type="application/ld+json">
    [
      {
        "@context": "https://schema.org",
        "@type": "Course",
        "name": "Bachata Beginners",
        "description": "Learn the basic step, partner connection, and simple turns. No experience needed. Available at all Latin Addiction UK locations.",
        "provider": { "@type": "Organization", "name": "Latin Addiction UK" },
        "offers": { "@type": "Offer", "price": "10", "priceCurrency": "GBP" }
      },
      {
        "@context": "https://schema.org",
        "@type": "Course",
        "name": "Bachata Improvers",
        "description": "Build your vocabulary with more turns, body movement and musicality. Available at Milton Keynes, Leicester, and Reading.",
        "provider": { "@type": "Organization", "name": "Latin Addiction UK" },
        "offers": { "@type": "Offer", "price": "10", "priceCurrency": "GBP" }
      },
      {
        "@context": "https://schema.org",
        "@type": "Course",
        "name": "Bachata Intermediate",
        "description": "Refine technique, learn complex combinations, and develop your own style. Available at Milton Keynes, Leicester, and Reading.",
        "provider": { "@type": "Organization", "name": "Latin Addiction UK" },
        "offers": { "@type": "Offer", "price": "10", "priceCurrency": "GBP" }
      },
      {
        "@context": "https://schema.org",
        "@type": "Course",
        "name": "Bachata Advanced",
        "description": "Advanced technique, intricate combinations, and performance quality for strong social dancers. Leicester only.",
        "provider": { "@type": "Organization", "name": "Latin Addiction UK" },
        "offers": { "@type": "Offer", "price": "10", "priceCurrency": "GBP" }
      }
    ]
  </script>
</BaseLayout>
