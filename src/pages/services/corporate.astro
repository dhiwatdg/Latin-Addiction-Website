---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { whatsappUrl } from '../../data/locations';

const waUrl = whatsappUrl("Hi! I'm interested in a corporate dance workshop for my team");
---

<BaseLayout
  title="Corporate Dance Workshops"
  description="Team-building dance workshops for companies and organisations. Latin Addiction UK delivers energising, inclusive Latin dance experiences — no experience needed."
>
  {/* ── HERO ── */}
  <section class="relative overflow-hidden bg-dark text-white flex items-center min-h-[45vh] px-5 py-14 md:px-8 md:py-20">
    <div class="hero-glow-left" aria-hidden="true"></div>
    <div class="hero-glow-right" aria-hidden="true"></div>

    <div class="relative z-10 max-w-[1200px] mx-auto w-full text-center">
      <div data-reveal class="flex items-center gap-3 mb-3 justify-center">
        <span class="text-rose-light uppercase text-xs font-bold tracking-[0.12em]">
          Corporate workshops
        </span>
      </div>

      <h1 data-reveal data-reveal-delay="1" class="font-display font-extrabold text-white leading-[1.05] tracking-[-0.02em] mb-5 text-[clamp(2.5rem,6vw,4.5rem)]">
        Dance workshops<br />for your team
      </h1>

      <p data-reveal data-reveal-delay="2" class="font-body font-light text-[clamp(1rem,2vw,1.15rem)] text-white/60 leading-[1.7] max-w-[560px] mb-8 mx-auto">
        A Latin dance experience your team will actually remember — energising, inclusive, and no experience needed.
      </p>

      <div data-reveal data-reveal-delay="3">
        <a href={waUrl} class="btn-rose" target="_blank" rel="noopener">
          Get in touch
        </a>
      </div>
    </div>
  </section>

  {/* ── WHAT'S OFFERED ── */}
  <section class="bg-white px-5 py-14 md:px-8 md:py-20 lg:px-8 lg:py-24">
    <div class="max-w-[860px] mx-auto">
      <div data-reveal class="mb-3">
        <span class="text-rose uppercase text-[0.75rem] font-bold tracking-[0.12em]">
          What we offer
        </span>
      </div>
      <h2 data-reveal data-reveal-delay="1" class="font-display font-semibold text-[clamp(1.75rem,3.5vw,2.75rem)] leading-[1.12] mb-6">
        A unique team experience
      </h2>
      <p data-reveal data-reveal-delay="2" class="text-[1rem] text-muted leading-[1.7] max-w-[640px] mb-10">
        We design and lead Latin dance sessions tailored to your team — from feel-good wellbeing events to full team-building days. Professional, energetic, and welcoming for everyone.
      </p>

      <div class="grid gap-5 md:grid-cols-3">
        <div data-reveal data-reveal-delay="1" class="bg-[#f5f5f5] rounded-[18px] p-6">
          <h3 class="font-display font-bold text-[1.05rem] mb-2">1-hour taster</h3>
          <p class="text-[0.88rem] text-muted leading-[1.7]">
            A high-energy introduction to Bachata or Salsa. Perfect for away days, lunch events, or as part of a larger programme.
          </p>
        </div>
        <div data-reveal data-reveal-delay="2" class="bg-[#f5f5f5] rounded-[18px] p-6">
          <h3 class="font-display font-bold text-[1.05rem] mb-2">90-min workshop</h3>
          <p class="text-[0.88rem] text-muted leading-[1.7]">
            More time to learn, laugh, and connect. Includes structured instruction plus a social dance-off to finish.
          </p>
        </div>
        <div data-reveal data-reveal-delay="3" class="bg-[#f5f5f5] rounded-[18px] p-6">
          <h3 class="font-display font-bold text-[1.05rem] mb-2">Half-day team event</h3>
          <p class="text-[0.88rem] text-muted leading-[1.7]">
            A full Latin dance experience — multiple styles, levels, and a social dance session. Ideal for larger teams or annual events.
          </p>
        </div>
      </div>
    </div>
  </section>

  {/* ── BENEFITS ── */}
  <section class="bg-[#f5f5f5] px-5 py-14 md:px-8 md:py-20 lg:px-8 lg:py-24">
    <div class="max-w-[860px] mx-auto">
      <div data-reveal class="mb-3">
        <span class="text-rose uppercase text-[0.75rem] font-bold tracking-[0.12em]">
          Why it works
        </span>
      </div>
      <h2 data-reveal data-reveal-delay="1" class="font-display font-semibold text-[clamp(1.75rem,3.5vw,2.75rem)] leading-[1.12] mb-8">
        Everyone leaves smiling
      </h2>

      <div class="grid gap-4 md:grid-cols-2">
        {[
          { title: 'Genuine bonding', body: 'Partner dancing breaks down barriers fast. Teams who dance together connect differently.' },
          { title: 'Stress relief', body: 'Movement and music are proven mood boosters. One session and the energy in the room shifts.' },
          { title: 'Truly inclusive', body: 'No dance experience required. No partner needed. We make sure everyone feels welcome from the first step.' },
          { title: 'Something different', body: 'Not a quiz night, not a bowling alley. A Latin dance event stands out — and gets talked about.' },
        ].map((item, i) => (
          <div data-reveal data-reveal-delay={String(i + 1)} class="bg-white border-[1.5px] border-[#e8e8e8] rounded-[18px] p-6">
            <h3 class="font-display font-bold text-[1rem] mb-1">{item.title}</h3>
            <p class="text-[0.88rem] text-muted leading-[1.7]">{item.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* ── HOW IT WORKS ── */}
  <section class="bg-white px-5 py-14 md:px-8 md:py-20 lg:px-8 lg:py-24">
    <div class="max-w-[1200px] mx-auto text-center">
      <div data-reveal class="mb-3">
        <span class="text-rose uppercase text-[0.75rem] font-bold tracking-[0.12em]">
          The process
        </span>
      </div>
      <h2 data-reveal data-reveal-delay="1" class="font-display font-semibold text-[clamp(1.75rem,3.5vw,2.75rem)] leading-[1.12] mb-10">
        Simple from start to finish
      </h2>

      <div class="grid gap-5 md:grid-cols-3 mt-8">
        <div data-reveal data-reveal-delay="1" class="step-card flex flex-col items-center">
          <div class="step-num w-[52px] h-[52px] rounded-full bg-rose-light border-2 border-[rgba(225,29,72,0.3)] flex items-center justify-center font-display font-bold text-[1.3rem] text-rose transition-all duration-300">
            1
          </div>
          <h3 class="font-display font-bold text-[1.05rem] mt-3 mb-1">Get in touch</h3>
          <p class="text-[0.88rem] text-muted">
            Tell us about your team, your event, and what you're looking for. We'll get back to you quickly.
          </p>
        </div>

        <div data-reveal data-reveal-delay="2" class="step-card flex flex-col items-center">
          <div class="step-num w-[52px] h-[52px] rounded-full bg-rose-light border-2 border-[rgba(225,29,72,0.3)] flex items-center justify-center font-display font-bold text-[1.3rem] text-rose transition-all duration-300">
            2
          </div>
          <h3 class="font-display font-bold text-[1.05rem] mt-3 mb-1">We design your session</h3>
          <p class="text-[0.88rem] text-muted">
            We tailor the format, style, and pace to suit your group — whether that's 10 people or 100.
          </p>
        </div>

        <div data-reveal data-reveal-delay="3" class="step-card flex flex-col items-center">
          <div class="step-num w-[52px] h-[52px] rounded-full bg-rose-light border-2 border-[rgba(225,29,72,0.3)] flex items-center justify-center font-display font-bold text-[1.3rem] text-rose transition-all duration-300">
            3
          </div>
          <h3 class="font-display font-bold text-[1.05rem] mt-3 mb-1">Your team dances</h3>
          <p class="text-[0.88rem] text-muted">
            We handle everything on the day. Your team just shows up and has fun.
          </p>
        </div>
      </div>
    </div>
  </section>

  {/* ── FINAL CTA ── */}
  <section class="relative overflow-hidden bg-dark px-5 py-14 md:px-8 md:py-20 lg:px-8 lg:py-24">
    <div class="hero-glow-left" aria-hidden="true"></div>
    <div class="hero-glow-right" aria-hidden="true"></div>

    <div class="relative z-10 max-w-[1200px] mx-auto text-center">
      <h2 data-reveal class="font-display font-bold text-white leading-[1.08] tracking-[-0.02em] mb-4 text-[clamp(2rem,5vw,3.5rem)]">
        Ready to book?
      </h2>
      <p data-reveal data-reveal-delay="1" class="text-[clamp(1rem,2vw,1.12rem)] text-white/[0.55] max-w-[480px] mx-auto leading-[1.7] mb-8">
        Get in touch and we'll put together a proposal for your team.
      </p>
      <div data-reveal data-reveal-delay="2">
        <a href={waUrl} class="btn-rose" style="font-size:1.02rem;padding:1rem 2.25rem;" target="_blank" rel="noopener">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
            <path d="M12 0C5.373 0 0 5.373 0 12c0 2.625.846 5.059 2.284 7.034L.789 23.492a.5.5 0 00.611.611l4.458-1.495A11.96 11.96 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-2.336 0-4.512-.703-6.32-1.905l-.44-.303-2.882.966.966-2.882-.303-.44A9.935 9.935 0 012 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/>
          </svg>
          Get in touch
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
