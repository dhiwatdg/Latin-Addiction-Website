---
import BaseLayout from '../layouts/BaseLayout.astro';
import ScheduleCard from '../components/ScheduleCard.astro';
import { locations, whatsappUrl, mapsUrl, PHONE_TEL, PHONE_DISPLAY } from '../data/locations';

const loc = locations.find(l => l.slug === 'milton-keynes')!;
const waUrl = whatsappUrl(loc.whatsappMessage);
const stylesLabel = loc.danceStyles.join(' & ');
---

<BaseLayout
  title="Bachata & Salsa Classes in Milton Keynes"
  description="Learn Bachata and Salsa every Monday at Midsummer Tap, Milton Keynes. Free first class, no partner needed. Beginners welcome."
>
  {/* ── SECTION 1: HERO (dark bg, shorter ~50vh) ── */}
  <section class="relative overflow-hidden bg-dark text-white flex items-center min-h-[50vh] md:min-h-[55vh] px-5 py-14 md:px-8 md:py-20 lg:px-8 lg:py-24">
    <div class="hero-glow-left" aria-hidden="true"></div>
    <div class="hero-glow-right" aria-hidden="true"></div>

    <div class="relative z-10 max-w-[1200px] mx-auto w-full text-center md:text-left">
      {/* Eyebrow */}
      <div data-reveal class="flex items-center gap-3 mb-3 justify-center md:justify-start">
        <span class="hidden md:block w-12 h-[3px] bg-rose-light rounded-sm" aria-hidden="true"></span>
        <span class="text-rose-light uppercase text-xs font-bold tracking-[0.12em]">
          {stylesLabel} classes &middot; {loc.name}
        </span>
      </div>

      {/* H1 */}
      <h1 data-reveal data-reveal-delay="1" class="font-display font-extrabold text-white leading-[1.05] tracking-[-0.02em] mb-5 text-[clamp(2.5rem,6vw,4.5rem)]">
        {stylesLabel} in {loc.name}
      </h1>

      {/* Subtitle */}
      <p data-reveal data-reveal-delay="2" class="font-body font-light text-[clamp(1rem,2vw,1.15rem)] text-white/60 leading-[1.7] max-w-[560px] mb-8 mx-auto md:mx-0">
        Every {loc.day} at {loc.venue}, {loc.address} {loc.postcode}
      </p>

      {/* CTA buttons */}
      <div data-reveal data-reveal-delay="3" class="flex flex-wrap gap-3 mb-6 justify-center md:justify-start">
        <a href={waUrl} class="btn-rose" target="_blank" rel="noopener">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
            <path d="M12 0C5.373 0 0 5.373 0 12c0 2.625.846 5.059 2.284 7.034L.789 23.492a.5.5 0 00.611.611l4.458-1.495A11.96 11.96 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-2.336 0-4.512-.703-6.32-1.905l-.44-.303-2.882.966.966-2.882-.303-.44A9.935 9.935 0 012 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/>
          </svg>
          Claim your free class
        </a>
        <a href="#schedule" class="btn-white-outline">
          See schedule ↓
        </a>
      </div>

      {/* Trust items */}
      <div data-reveal data-reveal-delay="4" class="flex flex-wrap gap-5 pt-6 mt-4 border-t border-white/[0.08] justify-center md:justify-start">
        <span class="text-[0.82rem] text-white/45 flex items-center gap-1.5">
          <span class="text-gold">★</span> {loc.badgeText}
        </span>
        <span class="text-[0.82rem] text-white/45">First class FREE</span>
        <span class="text-[0.82rem] text-white/45">Free social party</span>
      </div>
    </div>
  </section>

  {/* ── SECTION 2: SCHEDULE (light gray bg) ── */}
  <section id="schedule" class="bg-[#f5f5f5] px-5 py-14 md:px-8 md:py-20 lg:px-8 lg:py-24">
    <div class="max-w-[800px] mx-auto">
      <div data-reveal class="mb-3">
        <span class="text-rose uppercase text-[0.75rem] font-bold tracking-[0.12em]">
          Schedule
        </span>
      </div>
      <h2 data-reveal data-reveal-delay="1" class="font-display font-semibold text-[clamp(1.75rem,3.5vw,2.75rem)] leading-[1.12] mb-6">
        {loc.name} class times
      </h2>

      <div data-reveal data-reveal-delay="2">
        <ScheduleCard location={loc} />
      </div>

      {loc.note && (
        <p data-reveal class="text-[0.85rem] text-muted italic mt-3">{loc.note}</p>
      )}

      <div data-reveal class="mt-5">
        <a href={waUrl} class="btn-rose" target="_blank" rel="noopener">
          Join the {loc.name} class
        </a>
      </div>
    </div>
  </section>

  {/* ── SECTION 3: VENUE & PARKING (white bg) ── */}
  <section class="bg-white px-5 py-14 md:px-8 md:py-20 lg:px-8 lg:py-24">
    <div class="max-w-[800px] mx-auto">
      <h2 data-reveal class="font-display font-semibold text-[clamp(1.75rem,3.5vw,2.75rem)] leading-[1.12] mb-6">
        Finding us
      </h2>

      <div data-reveal data-reveal-delay="1" class="bg-[#f5f5f5] rounded-[18px] p-6 md:p-8">
        <p class="font-bold text-[1.05rem] mb-2">{loc.venue}</p>
        <p class="text-[0.92rem] text-muted mb-3">
          {loc.address} {loc.postcode}
        </p>
        <p class="text-[0.92rem] text-muted mb-4">
          🅿️ <strong>Parking:</strong> {loc.parking}
        </p>
        <a
          href={mapsUrl(loc.mapsQuery)}
          target="_blank"
          rel="noopener"
          class="text-rose-dark font-semibold text-[0.92rem] no-underline hover:underline"
        >
          Get directions →
        </a>
      </div>
    </div>
  </section>

  {/* ── SECTION 4: PRICING (light gray bg) ── */}
  <section class="bg-[#f5f5f5] px-5 py-14 md:px-8 md:py-20 lg:px-8 lg:py-24">
    <div class="max-w-[800px] mx-auto">
      <h2 data-reveal class="font-display font-semibold text-[clamp(1.75rem,3.5vw,2.75rem)] leading-[1.12] mb-6">
        Pricing
      </h2>

      <div data-reveal data-reveal-delay="1" class="bg-white border-[1.5px] border-[#e8e8e8] rounded-[18px] p-6 md:p-8">
        <p class="font-bold text-[1.05rem] mb-3">
          {loc.priceNote}
        </p>
        <p class="inline-flex items-center gap-2 bg-rose/[0.08] text-rose-9f font-semibold text-[0.88rem] px-4 py-2 rounded-full mb-4">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M13.5 4.5L6 12L2.5 8.5" stroke="#E11D48" stroke-width="2" stroke-linecap="round"/></svg>
          First class FREE
        </p>
        <p class="text-[0.88rem] text-muted leading-[1.7] mb-4">
          Cash and card accepted. Student &amp; NHS discount available — ask on WhatsApp.
        </p>
        <a href="/pricing" class="text-rose-dark font-semibold text-[0.92rem] no-underline hover:underline">
          See all pricing options →
        </a>
      </div>
    </div>
  </section>

  {/* ── SECTION 5: GETTING STARTED (white bg) ── */}
  <section class="bg-white px-5 py-14 md:px-8 md:py-20 lg:px-8 lg:py-24">
    <div class="max-w-[1200px] mx-auto text-center">
      <div data-reveal class="mb-3">
        <span class="text-rose uppercase text-[0.75rem] font-bold tracking-[0.12em]">
          The process
        </span>
      </div>
      <h2 data-reveal data-reveal-delay="1" class="font-display font-semibold text-[clamp(1.75rem,3.5vw,2.75rem)] leading-[1.12] mb-4">
        Getting started is <span class="font-display text-rose">ridiculously easy</span>
      </h2>

      <div class="grid gap-5 md:grid-cols-3 mt-8">
        <div data-reveal data-reveal-delay="1" class="step-card flex flex-col items-center">
          <div class="step-num w-[52px] h-[52px] rounded-full bg-rose-light border-2 border-[rgba(225,29,72,0.3)] flex items-center justify-center font-display font-bold text-[1.3rem] text-rose transition-all duration-300">
            1
          </div>
          <h3 class="font-display font-bold text-[1.05rem] mt-3 mb-1">Send us a message</h3>
          <p class="text-[0.88rem] text-muted">
            Just say hi on WhatsApp — that's it. We'll confirm the next class and answer any questions.
          </p>
        </div>

        <div data-reveal data-reveal-delay="2" class="step-card flex flex-col items-center">
          <div class="step-num w-[52px] h-[52px] rounded-full bg-rose-light border-2 border-[rgba(225,29,72,0.3)] flex items-center justify-center font-display font-bold text-[1.3rem] text-rose transition-all duration-300">
            2
          </div>
          <h3 class="font-display font-bold text-[1.05rem] mt-3 mb-1">Turn up</h3>
          <p class="text-[0.88rem] text-muted">
            Wear something comfortable. No special shoes needed. We'll be expecting you.
          </p>
        </div>

        <div data-reveal data-reveal-delay="3" class="step-card flex flex-col items-center">
          <div class="step-num w-[52px] h-[52px] rounded-full bg-rose-light border-2 border-[rgba(225,29,72,0.3)] flex items-center justify-center font-display font-bold text-[1.3rem] text-rose transition-all duration-300">
            3
          </div>
          <h3 class="font-display font-bold text-[1.05rem] mt-3 mb-1">Dance</h3>
          <p class="text-[0.88rem] text-muted">
            Your first class is free. Stay for the social party afterwards — that's where the real fun starts.
          </p>
        </div>
      </div>

      <div data-reveal data-reveal-delay="4" class="mt-6">
        <a href={waUrl} class="btn-rose" target="_blank" rel="noopener">
          Claim your free class
        </a>
      </div>
    </div>
  </section>

  {/* ── SECTION 6: FINAL CTA (dark bg) ── */}
  <section class="relative overflow-hidden bg-dark px-5 py-14 md:px-8 md:py-20 lg:px-8 lg:py-24">
    <div class="hero-glow-left" aria-hidden="true"></div>
    <div class="hero-glow-right" aria-hidden="true"></div>

    <div class="relative z-10 max-w-[1200px] mx-auto text-center">
      <div data-reveal class="mb-6">
        <span class="inline-flex items-center gap-2 bg-[rgba(225,29,72,0.12)] border border-[rgba(225,29,72,0.25)] rounded-full" style="padding:0.35rem 1rem;">
          <span class="cta-pulse-dot w-2 h-2 rounded-full bg-rose inline-block" aria-hidden="true"></span>
          <span class="text-rose-light text-[0.72rem] font-bold uppercase tracking-[0.1em]">
            Classes running now
          </span>
        </span>
      </div>

      <h2 data-reveal data-reveal-delay="1" class="font-display font-bold text-white leading-[1.08] tracking-[-0.02em] mb-4 text-[clamp(2rem,5vw,3.5rem)]">
        Your next {loc.day} could change everything.
      </h2>

      <p data-reveal data-reveal-delay="2" class="text-[clamp(1rem,2vw,1.12rem)] text-white/[0.55] max-w-[500px] mx-auto leading-[1.7] mb-8">
        One free class. No pressure. Just show up.
      </p>

      <div data-reveal data-reveal-delay="3" class="flex flex-wrap gap-3 justify-center">
        <a href={waUrl} class="btn-rose" style="font-size:1.02rem;padding:1rem 2.25rem;" target="_blank" rel="noopener">
          Claim your free class
        </a>
        <a href={`tel:${PHONE_TEL}`} class="btn-white-outline" style="font-size:1.02rem;padding:1rem 2.25rem;">
          Call {PHONE_DISPLAY}
        </a>
      </div>

      <div data-reveal data-reveal-delay="4" class="flex flex-wrap justify-center gap-x-5 gap-y-2.5 mt-8 pt-6 border-t border-white/[0.08]">
        {(['First class free', 'No partner needed', 'Complete beginners welcome', 'No commitment required'] as const).map((item) => (
          <span class="inline-flex items-center gap-1.5 text-[0.82rem] text-white/[0.55]">
            <svg width="15" height="15" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M13.5 4.5L6 12L2.5 8.5" stroke="#E11D48" stroke-width="2" stroke-linecap="round"/>
            </svg>
            {item}
          </span>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
